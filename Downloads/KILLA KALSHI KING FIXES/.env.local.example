# BTC Kalshi Intelligence Terminal — Environment Variables
# Copy this file to .env.local for local development
# On Vercel: Settings → Environment Variables → add each key

# ─── AI PROVIDER (at least one required) ────────────────────────────────────
# Claude (Anthropic) — Recommended. Primary AI advisor.
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq — Free tier fallback if Anthropic key not set.
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ─── CRON (optional) ────────────────────────────────────────────────────────
CRON_SECRET=btc-kalshi-cron-secret-change-this
