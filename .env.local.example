# NEVER commit this file to git
# Add your API keys here for local dev
# On Vercel, set these in Project Settings > Environment Variables

# Groq API key for AI analysis (primary)
GROQ_API_KEY=your_groq_key_here

# Cerebras API key for AI fallback (optional, uses GROQ_API_KEY if not set)
CEREBRAS_API_KEY=your_cerebras_key_here

# Cron job secret for authentication
CRON_SECRET=your_random_secret_here

# Vercel URL (auto-set in production, can set to localhost:3000 for local dev)
VERCEL_URL=localhost:3000

# Snyk token for security scanning in CI/CD
SNYK_TOKEN=your_snyk_token_here
